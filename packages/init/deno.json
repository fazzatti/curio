{
  "name": "@curio/init",
  "version": "0.1.6",
  "exports": "./mod.ts",
  "license": "MIT",
  "tasks": {
    "init": "deno run -A mod.ts",
    "lint": "deno lint mod.ts src scripts",
    "check": "deno check mod.ts src/mod.ts src/init.ts src/scaffold-assets.ts src/select-prompt.ts scripts/sync-template-bundle.ts",
    "test": "deno test -A --clean src",
    "test:file": "deno test -A --clean"
  },
  "publish": {
    "include": [
      "./mod.ts",
      "./src/**/*.ts",
      "./template/**/*",
      "./README.md",
      "./LICENSE",
      "./deno.json"
    ]
  },
  "imports": {
    "@curio/core": "jsr:@curio/core@^0.1.3",
    "@curio/core/admin": "jsr:@curio/core/admin@^0.1.3",
    "@curio/core/admin/modules/rbac": "jsr:@curio/core/admin/modules/rbac@^0.1.3",
    "@curio/core/auth": "jsr:@curio/core/auth@^0.1.3",
    "@curio/core/drizzle": "jsr:@curio/core/drizzle@^0.1.3",
    "@curio/core/http/oak": "jsr:@curio/core/http/oak@^0.1.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2"
  }
}
