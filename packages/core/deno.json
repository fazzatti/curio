{
  "name": "@curio/core",
  "version": "0.1.0",
  "exports": {
    ".": "./src/mod.ts",
    "./admin": "./src/admin.ts",
    "./admin/modules/audit": "./src/admin/modules/audit.ts",
    "./admin/modules/rbac": "./src/admin/modules/rbac.ts",
    "./admin/modules/sessions": "./src/admin/modules/sessions.ts",
    "./auth": "./src/auth.ts",
    "./drizzle": "./src/drizzle.ts",
    "./http/oak": "./src/http/oak-api.ts",
    "./openapi": "./src/openapi.ts",
    "./testing": "./src/testing.ts",
    "./value-object": "./src/value-object.ts"
  },
  "license": "MIT",
  "publish": {
    "include": [
      "./src/**/*.ts",
      "./src/**/*.tsx",
      "./README.md",
      "./LICENSE",
      "./deno.json"
    ],
    "exclude": [
      "./src/**/*.unit.test.ts",
      "./src/**/*.unit.test.tsx",
      "./src/OLD-reference/**"
    ]
  },
  "imports": {
    "@/": "./src/",
    "@convee": "jsr:@fifo/convee@^1.0.0",
    "@drizzle-orm": "npm:drizzle-orm@^0.44.5",
    "@drizzle-orm/postgres-js": "npm:drizzle-orm@^0.44.5/postgres-js",
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@postgres": "npm:postgres@^3.4.7",
    "@valibot/to-json-schema": "jsr:@valibot/to-json-schema@^1.6.0",
    "preact": "npm:preact@^10.27.2",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@valibot/valibot": "jsr:@valibot/valibot@^1.3.0"
  },
  "tasks": {
    "lint": "deno lint src",
    "check": "deno check src/mod.ts src/admin.ts src/admin/modules.ts src/admin/modules/audit.ts src/admin/modules/rbac.ts src/admin/modules/sessions.ts src/auth.ts src/drizzle.ts src/http/oak-api.ts src/openapi.ts src/testing.ts src/value-object.ts",
    "test": "deno test -A --parallel --clean --ignore='_*/' --ignore='src/OLD-reference/' src",
    "test:unit": "deno test -A --parallel --clean --ignore='_*/' --ignore='src/OLD-reference/' --ignore='**/*.integration.test.ts' --ignore='**/*.integration.test.tsx' src",
    "test:integration": "sh -c 'files=$(find src -type f \\( -name \"*.integration.test.ts\" -o -name \"*.integration.test.tsx\" \\)); if [ -z \"$files\" ]; then echo \"No integration tests found\"; else deno test -A --parallel --clean --ignore=\"_*/\" --ignore=\"src/OLD-reference/\" $files; fi'",
    "test:file": "deno test -A --parallel --clean --ignore='_*/' --ignore='src/OLD-reference/' src"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
