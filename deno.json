{
  "workspace": ["./packages/*"],

  "tasks": {
    "check": "deno check packages/core/src/mod.ts packages/core/src/admin.ts packages/core/src/admin/modules/audit.ts packages/core/src/admin/modules/rbac.ts packages/core/src/admin/modules/sessions.ts packages/core/src/auth.ts packages/core/src/drizzle.ts packages/core/src/http/oak-api.ts packages/core/src/openapi.ts packages/core/src/testing.ts packages/core/src/value-object.ts packages/init/mod.ts",
    "test": "deno test -A --parallel --clean --ignore='_*/' --ignore='packages/core/src/OLD-reference/' --ignore='**/*.integration.test.ts' --ignore='**/*.integration.test.tsx' --coverage=.coverage packages/core/src packages/init/src",
    "test:unit": "deno test -A --parallel --clean --ignore='_*/' --ignore='packages/core/src/OLD-reference/' --ignore='**/*.integration.test.ts' --ignore='**/*.integration.test.tsx' --coverage=.coverage packages/core/src packages/init/src",
    "test:integration": "sh -c 'files=$(find packages/core/src packages/init/src -type f \\( -name \"*.integration.test.ts\" -o -name \"*.integration.test.tsx\" \\)); if [ -z \"$files\" ]; then echo \"No integration tests found\"; else deno test -A --parallel --clean --ignore=\"_*/\" --coverage=.coverage $files; fi'",
    "test:file": "deno test -A --parallel --clean --ignore='_*/'",
    "init": "deno run -A ./packages/init/mod.ts"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.window", "deno.worker"],
    "strict": true
  },
  "exclude": ["node_modules", "_*", "dist", ".coverage"],
  "nodeModulesDir": "auto",
  "imports": {
    "jsr:@curio/core": "./packages/core",
    "jsr:@curio/core/admin": "./packages/core/src/admin.ts",
    "jsr:@curio/core/admin/modules/audit": "./packages/core/src/admin/modules/audit.ts",
    "jsr:@curio/core/admin/modules/rbac": "./packages/core/src/admin/modules/rbac.ts",
    "jsr:@curio/core/admin/modules/sessions": "./packages/core/src/admin/modules/sessions.ts",
    "jsr:@curio/core/auth": "./packages/core/src/auth.ts",
    "jsr:@curio/core/drizzle": "./packages/core/src/drizzle.ts",
    "jsr:@curio/core/http/oak": "./packages/core/src/http/oak-api.ts",
    "jsr:@curio/core/openapi": "./packages/core/src/openapi.ts",
    "jsr:@curio/core/testing": "./packages/core/src/testing.ts",
    "jsr:@curio/core/value-object": "./packages/core/src/value-object.ts",
    "@convee": "jsr:@fifo/convee@^1.0.0",
    "@drizzle-orm": "npm:drizzle-orm@^0.44.5",
    "@drizzle-orm/postgres-js": "npm:drizzle-orm@^0.44.5/postgres-js",
    "@valibot/valibot": "jsr:@valibot/valibot@^1.3.0",
    "@valibot/to-json-schema": "jsr:@valibot/to-json-schema@^1.6.0",
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@postgres": "npm:postgres@^3.4.7",
    "preact": "npm:preact@^10.27.2",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.2",
    "buffer": "npm:buffer@^6.0.3",
    "chalk": "npm:chalk@^5.6.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.0"
  }
}
